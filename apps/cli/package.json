{
  "name": "taskery",
  "private": false,
  "version": "0.2.6",
  "type": "module",
  "bin": {
    "taskery": "dist/bin/taskboard.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/bin/taskboard.ts",
    "build": "pnpm --filter taskery-shared build && pnpm --filter @taskboard/api build && pnpm --filter @taskboard/web build && pnpm run build:cli && pnpm run build:runtime",
    "build:cli": "tsc -p tsconfig.build.json",
    "build:runtime": "node scripts/build-runtime.mjs",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/**/*.test.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "prisma": "^6.19.2",
    "taskery-shared": "workspace:^0.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
