generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum TaskStatus {
  PENDING
  STARTED
  BLOCKED
  REVIEW
  COMPLETE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id        String       @id @default(cuid())
  title     String
  status    TaskStatus   @default(PENDING)
  priority  TaskPriority @default(MEDIUM)
  dueAt     DateTime?
  assignee  String?
  notes     String?
  position  Int
  version   Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  events TaskEvent[]

  @@index([status, position])
  @@index([updatedAt])
}

model TaskEvent {
  id        String   @id @default(cuid())
  taskId    String?
  eventType String
  payload   String?
  createdAt DateTime @default(now())

  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([taskId, createdAt])
}

model NotificationSettings {
  id            String   @id @default("global")
  enabled       Boolean  @default(true)
  dailyEnabled  Boolean  @default(true)
  dailyHoursCsv String   @default("10,13")
  weeklyEnabled Boolean  @default(true)
  weeklyDay     Int      @default(1)
  weeklyHour    Int      @default(10)
  windowMinutes Int      @default(15)
  updatedAt     DateTime @updatedAt
}
